# Cloud bus overlay — loaded by npm run dev:cloud / start:cloud
# Sets KAFKA_BOOTSTRAP_SERVERS to cloud bus tunnel (port 29092).
# This file is intentionally committed — it contains no secrets.
# Requires the cloud bus tunnel to be active: launchctl start ai.omninode.cloud-bus-tunnel
KAFKA_BOOTSTRAP_SERVERS=localhost:29092 # cloud-bus-ok OMN-4775
OMNIDASH_BUS_MODE=cloud
