# omnidash-v2 environment configuration template.
# Copy to `.env` and fill in values for your environment.
# Do NOT commit `.env` — it is ignored by .gitignore.
#
# OMN-10756: Data source defaults are now owned by contract.yaml.
# Run `npm run generate:config` after editing contract.yaml.
# The env vars below are OPTIONAL OVERRIDES only — the dashboard works without
# them using the contract defaults (sqlite, http://localhost:3002).

# ---------------------------------------------------------------------------
# Frontend (Vite — VITE_* vars are exposed to the browser)
# ---------------------------------------------------------------------------

# [OPTIONAL OVERRIDE] Data source mode. Default: contract.yaml data_source.default (sqlite).
# `file` reads from ./fixtures/ (zero infra). `http` reads via Express bridge.
# `sqlite` reads delegation projections via the Express bridge (recommended for local dev).
# Contract default is sqlite — leave unset unless you need a different mode.
# VITE_DATA_SOURCE=sqlite

# [OPTIONAL OVERRIDE] HTTP data-source URL. Default: contract.yaml data_source.url.
# Only needed when VITE_DATA_SOURCE=http and you want a non-default URL.
# VITE_HTTP_DATA_SOURCE_URL=http://localhost:3002

# [OPTIONAL OVERRIDE] SQLite data-source bridge URL. Default: contract.yaml data_source.url.
# Only needed when VITE_DATA_SOURCE=sqlite and you want a non-default URL.
# VITE_SQLITE_DATA_SOURCE_URL=http://localhost:3002

# [OPTIONAL OVERRIDE] WebSocket invalidation channel. Default: derived from bridge URL.
# VITE_WS_URL=ws://localhost:3002/ws

# Optional override for the Vite dev server port (default 3001).
# VITE_DEV_PORT=3001

# ---------------------------------------------------------------------------
# Frontend — AI Assistant
# ---------------------------------------------------------------------------

# Master toggle. Set to "false" to hide the assistant button + panel entirely.
# VITE_AGENT_ENABLED=true

# LLM backend host (no /v1 suffix; the client appends it).
# Required for production builds; in dev the Vite proxy stands in for it
# only if this is set. Leave unset to disable the proxy in dev.
# VITE_LLM_BASE_URL=http://your-llm-host:8000
# VITE_LLM_MODEL=qwen3-coder-30b-awq
# VITE_LLM_API_KEY=not-needed

# Optional fallback LLM (only consulted when callers pass useFallback=true).
# VITE_LLM_FALLBACK_URL=http://your-llm-fallback-host:8001
# VITE_LLM_FALLBACK_MODEL=deepseek-r1-14b-awq
# VITE_LLM_FALLBACK_API_KEY=not-needed

# ---------------------------------------------------------------------------
# Server (Express bridge — server/index.ts)
# ---------------------------------------------------------------------------

# [OPTIONAL OVERRIDE] Data source selector for the Express bridge.
# Default: contract.yaml data_source.default (sqlite).
# `postgres` reads from the Postgres projection API (requires OMNIDASH_ANALYTICS_DB_URL).
# `sqlite` reads from the local delegation SQLite DB (standalone installs).
# OMNIDASH_DATA_SOURCE=sqlite

# Postgres connection string for the analytics DB.
# REQUIRED when OMNIDASH_DATA_SOURCE=postgres.
# Not needed for standalone sqlite installs.
# OMNIDASH_ANALYTICS_DB_URL=postgresql://user:password@host:5432/omnidash_analytics

# [OPTIONAL OVERRIDE] SQLite DB path. Default: contract.yaml data_source.sqlite_db_path.
# (~/.omninode/delegation/delegation.sqlite)
# OMNIDASH_SQLITE_DB_PATH=/path/to/delegation.sqlite

# [OPTIONAL OVERRIDE] Express bridge URL (used by server-side routes for redirect).
# Default: contract.yaml data_source.url (http://localhost:3002).
# OMNIDASH_BRIDGE_URL=http://localhost:3002

# ---------------------------------------------------------------------------
# Build-time scripts
# ---------------------------------------------------------------------------

# Path to a checkout of omnibase_core. REQUIRED for `npm run types:generate`.
# OMNIBASE_CORE_PATH=/path/to/omnibase_core

# Path to a checkout of omnibase_infra. REQUIRED for `npm run generate:fixtures`.
# OMNIBASE_INFRA_PATH=/path/to/omnibase_infra
