# omnidash-v2 environment configuration template.
# Copy to `.env` and fill in values for your environment.
# Do NOT commit `.env` — it is ignored by .gitignore.

# ---------------------------------------------------------------------------
# Frontend (Vite — VITE_* vars are exposed to the browser)
# ---------------------------------------------------------------------------

# Data source mode. `file` reads from ./fixtures/ (default in dev, zero infra).
# `http` reads via the Express bridge declared by VITE_HTTP_DATA_SOURCE_URL.
# `sqlite` reads delegation projections from the local SQLite DB at ~/.omninode/delegation/delegation.sqlite
#   via the Express bridge; the server must be started with OMNIDASH_DATA_SOURCE=sqlite.
# VITE_DATA_SOURCE=file

# HTTP data-source URL. Required when VITE_DATA_SOURCE=http.
# VITE_HTTP_DATA_SOURCE_URL=http://localhost:3002

# SQLite data-source URL. REQUIRED when VITE_DATA_SOURCE=sqlite.
# No default — must be set explicitly to prevent silent misconfiguration.
# VITE_SQLITE_DATA_SOURCE_URL=http://localhost:3002

# WebSocket invalidation channel. Required when running with the Express bridge.
# Mirrors VITE_HTTP_DATA_SOURCE_URL but with the ws:// or wss:// scheme.
# VITE_WS_URL=ws://localhost:3002/ws

# Optional override for the Vite dev server port (default 3001).
# VITE_DEV_PORT=3001

# ---------------------------------------------------------------------------
# Frontend — AI Assistant
# ---------------------------------------------------------------------------

# Master toggle. Set to "false" to hide the assistant button + panel entirely.
# VITE_AGENT_ENABLED=true

# LLM backend host (no /v1 suffix; the client appends it).
# Required for production builds; in dev the Vite proxy stands in for it
# only if this is set. Leave unset to disable the proxy in dev.
# VITE_LLM_BASE_URL=http://your-llm-host:8000
# VITE_LLM_MODEL=qwen3-coder-30b-awq
# VITE_LLM_API_KEY=not-needed

# Optional fallback LLM (only consulted when callers pass useFallback=true).
# VITE_LLM_FALLBACK_URL=http://your-llm-fallback-host:8001
# VITE_LLM_FALLBACK_MODEL=deepseek-r1-14b-awq
# VITE_LLM_FALLBACK_API_KEY=not-needed

# ---------------------------------------------------------------------------
# Server (Express bridge — server/index.ts)
# ---------------------------------------------------------------------------

# Data source selector for the Express bridge.
# `postgres` (default) reads from the Postgres projection API (requires OMNIDASH_ANALYTICS_DB_URL).
# `sqlite` reads from the local delegation SQLite DB (standalone installs — no Docker/Kafka/Postgres required).
# OMNIDASH_DATA_SOURCE=postgres

# Postgres connection string for the analytics DB.
# REQUIRED when OMNIDASH_DATA_SOURCE=postgres (or when OMNIDASH_DATA_SOURCE is unset).
# Not needed for standalone sqlite installs.
# OMNIDASH_ANALYTICS_DB_URL=postgresql://user:password@host:5432/omnidash_analytics

# Override the SQLite DB path. Defaults to ~/.omninode/delegation/delegation.sqlite.
# Only used when OMNIDASH_DATA_SOURCE=sqlite.
# OMNIDASH_SQLITE_DB_PATH=/path/to/delegation.sqlite

# ---------------------------------------------------------------------------
# Build-time scripts
# ---------------------------------------------------------------------------

# Path to a checkout of omnibase_core. REQUIRED for `npm run types:generate`.
# OMNIBASE_CORE_PATH=/path/to/omnibase_core

# Path to a checkout of omnibase_infra. REQUIRED for `npm run generate:fixtures`.
# OMNIBASE_INFRA_PATH=/path/to/omnibase_infra
