# Part 4: AI Assistant Configuration

# LLM backend host only — no /v1 suffix (the client appends /v1 itself)
# Change to http://<lan-ip-redacted>:8001 to use DeepSeek-R1-14B fallback
VITE_LLM_BASE_URL=http://<lan-ip-redacted>:8000
VITE_LLM_MODEL=qwen3-coder-30b-awq
VITE_LLM_API_KEY=not-needed

# Set to "false" to disable the AI assistant entirely (hides the button + panel)
VITE_AGENT_ENABLED=true

# Part 1: API backend (omnidash v1 server)
VITE_API_BASE=http://localhost:3000
