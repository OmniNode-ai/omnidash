    "@vanilla-extract/recipes": "^0.5.7",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "mitt": "^3.0.1",
    "page-agent": "^1.7.1",
    "react": "^19.2.5",
