{
  "name": "omnidash",
  "version": "1.0.0",
  "description": "Composable widget dashboard for real-time observability — Vite + React with per-widget 2D and 3D variants.",
  "main": "index.js",
  "homepage": "https://github.com/OmniNode-ai/omnidash#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OmniNode-ai/omnidash.git"
  },
  "bugs": {
    "url": "https://github.com/OmniNode-ai/omnidash/issues"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "build:server": "tsc --noEmit --project tsconfig.node.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"eslint-rules/**/*.cjs\" --max-warnings=0",
    "generate:registry": "tsx scripts/generate-registry.ts",
    "generate:fixtures": "bash scripts/run-generate-fixtures.sh",
    "types:generate": "bash scripts/run-types-generate.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "dashboard",
    "observability",
    "vite",
    "react",
    "widgets",
    "visualization"
  ],
  "author": "OmniNode.ai Inc.",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
